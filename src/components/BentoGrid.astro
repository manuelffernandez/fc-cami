const snitchImg    = 'https://lh3.googleusercontent.com/aida/ADBb0ujwjyj5FgYcM0UBPcja_XJWBDsVcU7NWRAA_pncyxaPe-aLTR1KYUBHfGdYxRrmOAfQwTx9mqCx_GiRt3yzB-BA8rpGkxtxaf_21iZvy0fZRUbHC3CRDlBy2X-ii22ry3WBgjW4kKDJNK8_LzdyB8bU7oChU0kEySmnYBdGyiPtB8-haaALpUIHVzNfDwk1BVuU166OavHLW-4bfEhalu5PN6tVjjeTm6EFAy_zGa0mlat53lhdHBgnX_sQVhBGCUy8FhR9HQvycY0';
const cakeImg      = 'https://lh3.googleusercontent.com/aida/ADBb0uhgmfoQvhER2k_oo2FWYanGElh83rf9KvuRMdwGdebjX3paSLEar9heRa-BtaOD5ulfLfYhHxzGT-eHOIvBrE_H0c8yva7S4FBrO_v9OzGXneFJs-qF4msSzE9jpN9cjzuLibf5xVMDWlClru8xy8zJiFJ3JVIj6HQ9XX1Kh8_yQ8hfqi9LwaGiyk-h0CDtM4r7ZHgB6ybd_PGWTrQp9hvIK36_WUNuBNsHukCFv9nU1FpZ-Nviy8Xl5hr7NNJlTlk_-0iHWJk2zQ';
