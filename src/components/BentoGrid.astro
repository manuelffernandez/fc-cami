---
import CakeCard from './bento/CakeCard.astro';
import CelebrationCard from './bento/CelebrationCard.astro';
import GryffindorCard from './bento/GryffindorCard.astro';
import HarryCard from './bento/HarryCard.astro';
import SnitchCard from './bento/SnitchCard.astro';
import SyslogCard from './bento/SyslogCard.astro';
---

<section class="bento" aria-label="Colección de elementos">
  <GryffindorCard />
  <SnitchCard />
  <CakeCard />
  <CelebrationCard />
  <SyslogCard />
  <HarryCard />
</section>

<style>
  .bento {
    margin-top: var(--sp-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }

  @media (min-width: 768px) {
    .bento {
      grid-template-columns: repeat(3, 1fr);
    }

    .bento :global(.card--cake) {
      grid-column: span 2;
    }
  }

  @media (min-width: 1024px) {
    .bento {
      grid-template-columns: repeat(4, 1fr);
    }

    .bento :global(.card--celebration) {
      grid-column: span 2;
    }
  }
</style>
