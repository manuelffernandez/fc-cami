---
import "./terminal-panel/styles.css";
---
<article class="terminal" aria-label="Terminal de celebración" data-terminal-panel>
  <!-- Window chrome -->
  <header class="terminal__chrome">
    <div class="terminal__dots" aria-hidden="true">
      <span class="terminal__dot terminal__dot--red"></span>
      <span class="terminal__dot terminal__dot--yellow"></span>
      <span class="terminal__dot terminal__dot--cyan"></span>
    </div>
    <span class="terminal__title">root@celebration:~/cami_os</span>
    <div class="terminal__chrome-spacer" aria-hidden="true"></div>
  </header>

  <!-- Output -->
  <div class="terminal__body" data-terminal-body>
    <div class="terminal__static">
      <p class="terminal__line terminal__line--muted">
        Last login: Thu Apr 10 00:00:01 2025 from earth.v3
      </p>
      <p class="terminal__line">
        <span class="terminal__prompt-user">root@celebration:</span><span class="terminal__prompt-symbol">~#</span> sudo init adulthood
      </p>
      <p class="terminal__line terminal__line--ok">[ OK ] Starting Adulthood... done.</p>
      <p class="terminal__line terminal__line--ok">[ NO ] Loading Responsibilities... 1% (FAILED)</p>
      <p class="terminal__line terminal__line--ok">[ OK ] Unlocking New Skills... done.</p>
      <p class="terminal__line terminal__line--surface">EST. 2008_MOD_2026</p>

      <p class="terminal__line terminal__line--notice terminal__line--padded">
        Cami detected. Initiating celebration sequence...
      </p>

      <div class="terminal__tags">
        <span class="terminal__tag terminal__tag--primary">PARTY_BIT: 1</span>
        <span class="terminal__tag terminal__tag--secondary">CAKE_VAL: TRUE</span>
        <span class="terminal__tag terminal__tag--tertiary">MAGIC_LEVEL: MAX</span>
      </div>
    </div>

    <div class="terminal__history" data-terminal-history></div>

    <div class="terminal__input" data-terminal-input>
      <span class="terminal__prompt" aria-hidden="true">
        <span class="terminal__prompt-user">root@celebration:</span><span class="terminal__prompt-symbol">~#</span>
      </span>
      <div class="terminal__composer" data-terminal-composer>
        <div class="terminal__textarea-mirror" aria-hidden="true" data-terminal-mirror></div>
        <textarea
          class="terminal__textarea"
          aria-label="Terminal editable"
          autocapitalize="off"
          autocomplete="off"
          autocorrect="off"
          data-terminal-textarea
          enterkeyhint="enter"
          inputmode="text"
          rows="1"
          spellcheck="false"
        ></textarea>
      </div>
    </div>
  </div>
</article>

<script>
  import setupTerminalPanel from "./terminal-panel/client";

  setupTerminalPanel();
</script>
