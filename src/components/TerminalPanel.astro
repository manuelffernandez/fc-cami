---
---
<article class="terminal" aria-label="Terminal de celebración" data-terminal-panel>
  <!-- Window chrome -->
  <header class="terminal__chrome">
    <div class="terminal__dots" aria-hidden="true">
      <span class="terminal__dot terminal__dot--red"></span>
      <span class="terminal__dot terminal__dot--yellow"></span>
      <span class="terminal__dot terminal__dot--cyan"></span>
    </div>
    <span class="terminal__title">root@celebration:~/cami_os</span>
    <div class="terminal__chrome-spacer" aria-hidden="true"></div>
  </header>

  <!-- Output -->
  <div class="terminal__body" data-terminal-body>
    <div class="terminal__static">
      <p class="terminal__line terminal__line--muted">
        Last login: Thu Apr 10 00:00:01 2025 from earth.v3
      </p>
      <p class="terminal__line">
        <span class="terminal__prompt-user">root@celebration:</span><span class="terminal__prompt-symbol">~#</span> sudo init adulthood
      </p>
      <p class="terminal__line terminal__line--ok">[ OK ] Starting Adulthood... done.</p>
      <p class="terminal__line terminal__line--ok">[ NO ] Loading Responsibilities... 1% (FAILED)</p>
      <p class="terminal__line terminal__line--ok">[ OK ] Unlocking New Skills... done.</p>
      <p class="terminal__line terminal__line--surface">EST. 2008_MOD_2026</p>

      <p class="terminal__line terminal__line--notice terminal__line--padded">
        Cami detected. Initiating celebration sequence...
      </p>

      <div class="terminal__tags">
        <span class="terminal__tag terminal__tag--primary">PARTY_BIT: 1</span>
        <span class="terminal__tag terminal__tag--secondary">CAKE_VAL: TRUE</span>
        <span class="terminal__tag terminal__tag--tertiary">MAGIC_LEVEL: MAX</span>
      </div>
    </div>

    <div class="terminal__history" data-terminal-history></div>

    <div class="terminal__input" data-terminal-input>
      <span class="terminal__prompt" aria-hidden="true">
        <span class="terminal__prompt-user">root@celebration:</span><span class="terminal__prompt-symbol">~#</span>
      </span>
      <div class="terminal__composer" data-terminal-composer>
        <div class="terminal__textarea-mirror" aria-hidden="true" data-terminal-mirror></div>
        <textarea
          class="terminal__textarea"
          aria-label="Terminal editable"
          autocapitalize="off"
          autocomplete="off"
          autocorrect="off"
          data-terminal-textarea
          enterkeyhint="enter"
          inputmode="text"
          rows="1"
          spellcheck="false"
        ></textarea>
      </div>
    </div>
  </div>
</article>

<script>
  const terminals = document.querySelectorAll('[data-terminal-panel]');
  const promptUserLabel = 'root@celebration:';
  const promptSymbolLabel = '~#';

  const createPromptFragment = () => {
    const fragment = document.createDocumentFragment();
    const promptUser = document.createElement('span');
    const promptSymbol = document.createElement('span');

    promptUser.className = 'terminal__prompt-user';
    promptUser.textContent = promptUserLabel;

    promptSymbol.className = 'terminal__prompt-symbol';
    promptSymbol.textContent = promptSymbolLabel;

    fragment.append(promptUser, promptSymbol);

    return fragment;
  };

  const createCommandEntry = (value) => {
    const line = document.createElement('p');
    line.className = 'terminal__line';
    line.append(createPromptFragment());

    if (value.length > 0) {
      line.append(document.createTextNode(` ${value}`));
    }

    return line;
  };

  const createOutputEntry = ({ value, tone = 'surface' }) => {
    const line = document.createElement('p');
    const toneClassByName = {
      muted: 'terminal__line--muted',
      ok: 'terminal__line--ok',
      notice: 'terminal__line--notice',
      error: 'terminal__line--error',
      surface: 'terminal__line--surface',
    };

    line.className = `terminal__line ${toneClassByName[tone] ?? toneClassByName.surface}`;
    line.textContent = value;

    return line;
  };

  const availableCommands = {
    clear: () => ({ clearHistory: true }),
  };

  const executeCommand = (rawCommand) => {
    const normalizedCommand = rawCommand.trim();

    if (!normalizedCommand) {
      return {
        clearHistory: false,
        outputs: [],
      };
    }

    const [commandName] = normalizedCommand.split(/\s+/);
    const command = availableCommands[commandName.toLowerCase()];

    if (!command) {
      return {
        clearHistory: false,
        outputs: [
          {
            tone: 'error',
            value: `bash: ${commandName}: command not found`,
          },
        ],
      };
    }

    return command({ rawCommand, normalizedCommand });
  };

  const moveCaretToEnd = (textarea) => {
    const cursorAtEnd = textarea.value.length;
    textarea.setSelectionRange(cursorAtEnd, cursorAtEnd);
  };

  const focusTextarea = (textarea, { preventScroll = false } = {}) => {
    if (preventScroll) {
      try {
        textarea.focus({ preventScroll: true });
        return;
      } catch {
        // Fallback for browsers without focus options support.
      }
    }

    textarea.focus();
  };

  const requestTerminalAttention = (textarea) => {
    const terminal = textarea.closest('[data-terminal-panel]');

    if (!(terminal instanceof HTMLElement)) {
      return;
    }

    terminal.classList.remove('terminal--attention');
    void terminal.offsetWidth;
    terminal.classList.add('terminal--attention');
    focusTextarea(textarea, { preventScroll: true });
    moveCaretToEnd(textarea);
  };

  const syncTerminalInput = (terminal) => {
    const body = terminal.querySelector('[data-terminal-body]');
    const history = terminal.querySelector('[data-terminal-history]');
    const container = terminal.querySelector('[data-terminal-input]');
    const composer = terminal.querySelector('[data-terminal-composer]');
    const mirror = terminal.querySelector('[data-terminal-mirror]');
    const textarea = terminal.querySelector('[data-terminal-textarea]');
    let syncFrame = 0;
    let entries = [];
    let previousComposerHeight = 0;

    if (
      !(body instanceof HTMLElement)
      || !(history instanceof HTMLElement)
      || !(container instanceof HTMLElement)
      || !(composer instanceof HTMLElement)
      || !(mirror instanceof HTMLElement)
      || !(textarea instanceof HTMLTextAreaElement)
    ) {
      return;
    }

    const renderHistory = () => {
      history.replaceChildren(
        ...entries.map((entry) => {
          if (entry.type === 'command') {
            return createCommandEntry(entry.value);
          }

          return createOutputEntry(entry);
        }),
      );

      body.scrollTop = body.scrollHeight;
    };

    const syncComposer = ({ forceScroll = false } = {}) => {
      mirror.textContent = `${textarea.value}\u200b`;
      const nextComposerHeight = composer.offsetHeight;

      if (forceScroll || nextComposerHeight !== previousComposerHeight) {
        body.scrollTop = body.scrollHeight;
      }

      previousComposerHeight = nextComposerHeight;
    };

    const submitCommand = () => {
      const rawCommand = textarea.value.replace(/[\r\n]+/g, ' ').trimEnd();
      const result = executeCommand(rawCommand);

      if (result.clearHistory) {
        entries = [];
        renderHistory();
      } else {
        entries.push({
          type: 'command',
          value: rawCommand,
        });

        if (result.outputs.length > 0) {
          entries.push(
            ...result.outputs.map((output) => ({
              ...output,
              type: 'output',
            })),
          );
        }

        renderHistory();
      }

      textarea.value = '';
      scheduleComposerSync({ forceScroll: true });
    };

    const scheduleComposerSync = (options) => {
      cancelAnimationFrame(syncFrame);
      syncFrame = requestAnimationFrame(() => {
        syncComposer(options);
      });
    };

    container.addEventListener('click', (event) => {
      if (event.target === textarea) {
        return;
      }

      focusTextarea(textarea, { preventScroll: true });
      moveCaretToEnd(textarea);
    });

    body.addEventListener('click', (event) => {
      if (event.target === textarea) {
        return;
      }

      focusTextarea(textarea, { preventScroll: true });
      moveCaretToEnd(textarea);
    });

    document.addEventListener('terminal:focus-request', () => {
      requestTerminalAttention(textarea);
    });

    textarea.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        submitCommand();
        return;
      }

      if (event.ctrlKey || event.metaKey || event.altKey) {
        return;
      }

      const isPlainCharacter = event.key.length === 1 && !event.ctrlKey && !event.metaKey && !event.altKey;
      const navigationKeys = new Set([
        'ArrowDown',
        'ArrowLeft',
        'ArrowRight',
        'ArrowUp',
        'Backspace',
        'Delete',
        'End',
        'Escape',
        'Home',
        'Tab',
      ]);
      const isAllowedKey = isPlainCharacter || navigationKeys.has(event.key);

      if (!isAllowedKey) {
        event.preventDefault();
      }
    });

    textarea.addEventListener('beforeinput', (event) => {
      const allowedTypes = new Set([
        'deleteByCut',
        'insertText',
        'insertCompositionText',
        'insertFromPaste',
        'deleteContentBackward',
        'deleteContentForward',
      ]);

      if (!allowedTypes.has(event.inputType)) {
        event.preventDefault();
      }
    });

    textarea.addEventListener('input', () => {
      const sanitizedValue = textarea.value.replace(/[\r\n]+/g, ' ');

      if (sanitizedValue !== textarea.value) {
        textarea.value = sanitizedValue;
      }

      scheduleComposerSync();
    });
    textarea.addEventListener('focus', () => scheduleComposerSync({ forceScroll: true }));

    syncComposer({ forceScroll: true });
  };

  terminals.forEach((terminal) => syncTerminalInput(terminal));
</script>

<style>
  .terminal {
    background-color: var(--clr-surface-low);
    border: 1px dotted var(--clr-outline-variant);
    padding: var(--sp-1);
    box-shadow: var(--shadow-panel);
  }

  .terminal--attention {
    animation: terminal-attention 760ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes terminal-attention {
    0% {
      border-color: var(--clr-outline-variant);
      box-shadow: var(--shadow-panel);
    }

    38% {
      border-color: color-mix(in srgb, var(--clr-primary) 88%, white 12%);
      box-shadow:
        var(--shadow-panel),
        0 0 0 0.2rem color-mix(in srgb, var(--clr-primary) 42%, transparent),
        0 0 1.25rem color-mix(in srgb, var(--clr-primary) 32%, transparent);
    }

    68% {
      border-color: color-mix(in srgb, var(--clr-primary) 72%, white 28%);
      box-shadow:
        var(--shadow-panel),
        0 0 0 0.16rem color-mix(in srgb, var(--clr-primary) 28%, transparent),
        0 0 0.85rem color-mix(in srgb, var(--clr-primary) 20%, transparent);
    }

    100% {
      border-color: var(--clr-outline-variant);
      box-shadow: var(--shadow-panel);
    }
  }

  /* ── Chrome (title bar) ── */
  .terminal__chrome {
    background-color: var(--clr-surface-highest);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 1px solid color-mix(in srgb, var(--clr-outline-variant) 30%, transparent);
  }

  .terminal__dots {
    display: flex;
    gap: var(--sp-2);
  }

  .terminal__dot {
    display: block;
    width: 0.75rem;
    height: 0.75rem;
  }

  .terminal__dot--red    { background-color: var(--clr-error); }
  .terminal__dot--yellow { background-color: var(--clr-tertiary); }
  .terminal__dot--cyan   { background-color: var(--clr-primary); }

  .terminal__title {
    font-size: 0.625rem;
    color: var(--clr-on-surface-variant);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .terminal__chrome-spacer {
    width: 3rem;
  }

  /* ── Body ── */
  .terminal__body {
    padding: var(--sp-6);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--clr-primary-dim);
    block-size: clamp(18rem, 42vw, 24rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    overflow-anchor: none;
    scrollbar-width: thin;
    scrollbar-color: var(--clr-primary) color-mix(in srgb, var(--clr-primary) 12%, transparent);
  }

  .terminal__body::-webkit-scrollbar {
    width: 0.875rem;
  }

  .terminal__body::-webkit-scrollbar-track {
    background-color: color-mix(in srgb, var(--clr-primary) 12%, transparent);
    border-left: 1px solid color-mix(in srgb, var(--clr-outline-variant) 50%, transparent);
  }

  .terminal__body::-webkit-scrollbar-thumb {
    background-color: var(--clr-primary);
    border: 2px solid var(--clr-surface-low);
  }

  .terminal :global(.terminal__line) {
    margin-top: var(--sp-2);
  }

  .terminal :global(.terminal__line--muted)   { color: var(--clr-on-surface-variant); }
  .terminal :global(.terminal__line--ok)      { color: var(--clr-tertiary-fixed); }
  .terminal :global(.terminal__line--surface) { color: var(--clr-on-surface); }
  .terminal :global(.terminal__line--notice)  { color: var(--clr-secondary-fixed); }
  .terminal :global(.terminal__line--error)   { color: var(--clr-error); }
  .terminal :global(.terminal__line--padded)  { padding-top: var(--sp-4); }

  .terminal :global(.terminal__prompt-user)   { color: var(--clr-secondary); }
  .terminal :global(.terminal__prompt-symbol) { color: var(--clr-primary); }

  .terminal__history:empty {
    display: none;
  }

  .terminal__input {
    margin-top: var(--sp-2);
    display: flex;
    align-items: flex-start;
    gap: var(--sp-2);
    color: var(--clr-primary);
    cursor: text;
  }

  .terminal__prompt {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .terminal__composer {
    flex: 1 1 auto;
    position: relative;
    min-width: 0;
  }

  .terminal__textarea,
  .terminal__textarea-mirror {
    display: block;
    inline-size: 100%;
    min-width: 0;
    padding: 0;
    border: 0;
    margin: 0;
    font: inherit;
    line-height: inherit;
    letter-spacing: inherit;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .terminal__textarea-mirror {
    visibility: hidden;
    pointer-events: none;
    min-block-size: 1lh;
  }

  .terminal__textarea {
    position: absolute;
    inset: 0;
    block-size: 100%;
    min-block-size: 100%;
    resize: none;
    overflow: hidden;
    background: transparent;
    color: inherit;
    caret-color: var(--clr-primary);
    outline: none;
  }

  .terminal__textarea::placeholder {
    color: transparent;
  }

  .terminal__textarea:focus-visible {
    outline: none;
  }

  /* ── Inline tags ── */
  .terminal__tags {
    margin-top: var(--sp-2);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .terminal__tag {
    padding: 0 var(--sp-2);
    font-size: 0.875rem;
  }

  .terminal__tag--primary {
    background-color: color-mix(in srgb, var(--clr-primary) 20%, transparent);
    color: var(--clr-primary);
    border: 1px solid color-mix(in srgb, var(--clr-primary) 40%, transparent);
  }

  .terminal__tag--secondary {
    background-color: color-mix(in srgb, var(--clr-secondary) 20%, transparent);
    color: var(--clr-secondary);
    border: 1px solid color-mix(in srgb, var(--clr-secondary) 40%, transparent);
  }

  .terminal__tag--tertiary {
    background-color: color-mix(in srgb, var(--clr-tertiary) 20%, transparent);
    color: var(--clr-tertiary);
    border: 1px solid color-mix(in srgb, var(--clr-tertiary) 40%, transparent);
  }

  @media (max-width: 40rem) {
    .terminal__body {
      block-size: 18rem;
      padding: var(--sp-5);
    }

    .terminal__input {
      gap: var(--sp-1);
    }
  }
</style>
