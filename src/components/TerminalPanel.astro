---
import "./terminal-panel/styles.css";
---
<article class="terminal" aria-label="Terminal de celebración" data-terminal-panel>
  <!-- Window chrome -->
  <header class="terminal__chrome">
    <div class="terminal__dots">
      <span
        class="terminal__dot terminal__dot--red"
        data-secret-trigger
        role="button"
        tabindex="0"
        aria-label="Descubrir secreto"
      ></span>
      <span class="terminal__dot terminal__dot--yellow" aria-hidden="true"></span>
      <span class="terminal__dot terminal__dot--cyan" aria-hidden="true"></span>
    </div>
    <span class="terminal__title">root@celebration:~/cami_os</span>
    <div class="terminal__chrome-spacer" aria-hidden="true"></div>
  </header>

  <!-- Output -->
  <div class="terminal__body" data-terminal-body>
    <div class="terminal__static">
      <p class="terminal__line terminal__line--muted">
        Last login: Thu Apr 10 00:00:01 2025 from earth.v3
      </p>
      <p class="terminal__line">
        <span class="terminal__prompt-user">root@celebration:</span><span class="terminal__prompt-symbol">~#</span> sudo init adulthood
      </p>
      <p class="terminal__line terminal__line--ok">[ OK ] Starting Adulthood... done.</p>
      <p class="terminal__line terminal__line--ok">[ NO ] Loading Responsibilities... 1% (FAILED)</p>
      <p class="terminal__line terminal__line--ok">[ OK ] Unlocking New Skills... done.</p>
      <p class="terminal__line terminal__line--surface">EST. 2008_MOD_2026</p>

      <p class="terminal__line terminal__line--notice terminal__line--padded">
        Cami detected. Initiating celebration sequence...
      </p>

      <div class="terminal__tags">
        <span class="terminal__tag terminal__tag--primary">PARTY_BIT: 1</span>
        <span class="terminal__tag terminal__tag--secondary">CAKE_VAL: TRUE</span>
        <span class="terminal__tag terminal__tag--tertiary">MAGIC_LEVEL: MAX</span>
      </div>
    </div>

    <div class="terminal__history" data-terminal-history></div>

    <div class="terminal__input" data-terminal-input>
      <span class="terminal__prompt" aria-hidden="true">
        <span class="terminal__prompt-user">root@celebration:</span><span class="terminal__prompt-symbol">~#</span>
      </span>
      <div class="terminal__composer" data-terminal-composer>
        <div class="terminal__textarea-mirror" aria-hidden="true" data-terminal-mirror></div>
        <textarea
          class="terminal__textarea"
          aria-label="Terminal editable"
          autocapitalize="off"
          autocomplete="off"
          autocorrect="off"
          data-terminal-textarea
          enterkeyhint="enter"
          inputmode="text"
          rows="1"
          spellcheck="false"
        ></textarea>
      </div>
    </div>
  </div>
</article>

<style is:global>
  @keyframes confetti-particle {
    0% {
      transform: translate(0, 0) scale(1) rotate(0deg);
      opacity: 1;
    }
    100% {
      transform: translate(var(--cx), var(--cy)) scale(0) rotate(var(--cr));
      opacity: 0;
    }
  }

  .confetti-particle {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    animation: confetti-particle 2.4s ease-out forwards;
  }

  /* Secret star animation */
  .secret-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    animation: secret-darken 0.3s steps(4) forwards;
  }

  .secret-overlay--fade-out {
    animation: secret-fade-out 0.5s steps(4) forwards;
  }

  @keyframes secret-darken {
    from { background: rgba(0, 0, 0, 0); }
    to { background: rgba(0, 0, 0, 0.7); }
  }

  @keyframes secret-fade-out {
    to { background: rgba(0, 0, 0, 0); opacity: 0; }
  }

  .secret-star {
    position: relative;
    width: 0;
    height: 0;
    image-rendering: pixelated;
  }

  .secret-pixel {
    position: absolute;
    background: #ffd166;
    transform: translate(-50%, -50%);
    opacity: 0;
    animation: secret-pixel-place 1ms steps(1) forwards;
  }

  @keyframes secret-pixel-place {
    to { opacity: 1; }
  }

  .secret-shard {
    position: absolute;
    pointer-events: none;
    transform: translate(-50%, -50%);
    animation: secret-shard-fly 0.7s steps(8) forwards;
  }

  @keyframes secret-shard-fly {
    0% {
      translate: 0 0;
      opacity: 1;
    }
    100% {
      translate: var(--cx) var(--cy);
      opacity: 0;
    }
  }

  /* harryp — patronum image */
  .harryp-image {
    max-width: clamp(160px, 40vw, 320px);
    image-rendering: pixelated;
    opacity: 0;
    animation: harryp-image-in 0.4s steps(4) 0.3s forwards;
  }

  .harryp-image--mirrored {
    transform: scaleX(-1);
  }

  @keyframes harryp-image-in {
    to { opacity: 1; }
  }

  .harryp-spell {
    position: absolute;
    top: calc(50% + 100px);
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Dancing Script', cursive;
    color: #c8b8ff;
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    white-space: nowrap;
    opacity: 0;
    animation: harryp-spell-in 0.6s ease-out 1400ms forwards;
  }

  @keyframes harryp-spell-in {
    from { opacity: 0; transform: translateX(-50%) translateY(8px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .harryp-flash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    background: #d0eaff;
    animation: harryp-flash-anim 0.6s steps(5) forwards;
  }

  @keyframes harryp-flash-anim {
    0%   { opacity: 0; }
    20%  { opacity: 0.85; }
    100% { opacity: 0; }
  }

  .harryp-particle {
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    image-rendering: pixelated;
    animation: harryp-particle-fly 0.9s steps(12) forwards;
  }

  @keyframes harryp-particle-fly {
    0%   { transform: translate(0, 0) scale(1); opacity: 1; }
    100% { transform: translate(var(--cx), var(--cy)) scale(0); opacity: 0; }
  }

  /* snitch — flying element */
  .snitch {
    position: fixed;
    z-index: 9999;
    pointer-events: none;
    animation-timing-function: linear;
    animation-fill-mode: forwards;
  }

  .snitch-img {
    width: clamp(96px, 16vw, 160px);
    image-rendering: pixelated;
    display: block;
  }

  /* stylinson — heart pixel art */
  .stylinson-scene {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 105px 160px 170px;
  }

  .stylinson-img {
    width: clamp(90px, 14vw, 130px);
    image-rendering: pixelated;
    position: relative;
    z-index: 1;
    margin-top: 40px;
    opacity: 0;
    animation: harryp-image-in 0.4s steps(4) 0.2s forwards;
  }

  .stylinson-img--mirror {
    transform: scaleX(-1);
  }

  .stylinson-heart {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 0;
    height: 0;
    z-index: 2;
    pointer-events: none;
  }

  .stylinson-pixel {
    position: absolute;
    background: #ff3355;
    transform: translate(-50%, -50%);
    opacity: 0;
    image-rendering: pixelated;
    animation: secret-pixel-place 1ms steps(1) forwards;
  }

  .stylinson-text {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    font-family: 'Dancing Script', cursive;
    color: #ffffff;
    text-shadow: 0 0 12px rgba(255, 51, 85, 0.9), 0 2px 4px rgba(0,0,0,0.6);
    font-size: clamp(1.5rem, 5vw, 2rem);
    white-space: nowrap;
    text-align: center;
    opacity: 0;
    animation: stylinson-text-in 0.6s ease-out forwards;
  }

  @keyframes stylinson-text-in {
    from { opacity: 0; transform: translate(-50%, calc(-50% + 8px)); }
    to   { opacity: 1; transform: translate(-50%, -50%); }
  }

  /* tattoo — "18" drawn pixel by pixel */
  .tattoo-container {
    position: relative;
    width: 0;
    height: 0;
    image-rendering: pixelated;
  }

  .tattoo-container--buzzing {
    animation: tattoo-buzz 0.08s steps(2) infinite;
  }

  @keyframes tattoo-buzz {
    0%  { transform: translate(0, 0); }
    50% { transform: translate(1px, -1px); }
  }

  .tattoo-pixel {
    position: absolute;
    background: #ff85a1;
    transform: translate(-50%, -50%);
    opacity: 0;
    image-rendering: pixelated;
    animation: secret-pixel-place 1ms steps(1) forwards;
    transition: background 0.4s, box-shadow 0.4s;
  }

  .tattoo-container--glow .tattoo-pixel {
    background: #ff5f8a;
    box-shadow: 0 0 8px #ff85a1, 0 0 20px rgba(255, 133, 161, 0.5);
  }

  /* golden — pixel rain */
  .golden-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    pointer-events: none;
    animation: secret-darken 0.5s steps(4) forwards;
  }

  .golden-overlay--out {
    animation: secret-fade-out 0.8s steps(4) forwards;
  }

  .golden-pixel {
    position: absolute;
    top: -20px;
    background: #ffd166;
    image-rendering: pixelated;
    opacity: 0;
    animation-name: golden-fall;
    animation-timing-function: steps(14);
    animation-fill-mode: forwards;
  }

  @keyframes golden-fall {
    0%   { transform: translateY(0); opacity: 0; }
    8%   { opacity: 1; }
    88%  { opacity: 1; }
    100% { transform: translateY(112vh); opacity: 0; }
  }

  .golden-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-mono);
    color: #ffd166;
    font-size: clamp(1rem, 4vw, 1.8rem);
    letter-spacing: 0.35em;
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0;
    text-shadow: 0 0 24px rgba(255, 209, 102, 0.9);
    animation: golden-text-in 0.5s steps(3) 1800ms forwards;
  }

  @keyframes golden-text-in {
    to { opacity: 1; }
  }

  /* unlock modal */
  .unlock-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    animation: unlock-modal-in 0.2s steps(3) forwards;
  }

  .unlock-modal--out {
    animation: unlock-modal-out 0.3s steps(3) forwards;
  }

  @keyframes unlock-modal-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes unlock-modal-out {
    to { opacity: 0; }
  }

  .unlock-modal__box {
    background: var(--clr-surface-low);
    border: 1px dotted var(--clr-primary);
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    text-align: center;
    max-width: min(90vw, 28rem);
    box-shadow: var(--shadow-panel);
  }

  .unlock-modal__title {
    color: var(--clr-primary);
    font-size: 0.875rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .unlock-modal__msg {
    color: var(--clr-on-surface-variant);
    font-size: 0.8125rem;
  }

  .unlock-modal__btn {
    margin-top: 0.5rem;
    background: transparent;
    border: 1px solid var(--clr-primary);
    color: var(--clr-primary);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.25rem 1.25rem;
    cursor: pointer;
    transition: background 0.15s steps(2);
  }

  .unlock-modal__btn:hover {
    background: color-mix(in srgb, var(--clr-primary) 15%, transparent);
  }
</style>

<script>
  import setupTerminalPanel from "./terminal-panel/client";

  setupTerminalPanel();
</script>
