---
<footer class="footer">
  <p class="footer__copy">(C) 2026 TERMINAL_OS // BIRTHDAY_MODE.INIT</p>

  <nav class="footer__links" aria-label="Footer links">
    <a href="#" class="footer__link">HELP</a>
    <a href="#" class="footer__link">SHUTDOWN</a>
  </nav>
</footer>

<style>
  .footer {
    position: fixed;
    bottom: 0;
    width: 100%;
    background-color: var(--clr-nav);
    border-top: 1px dotted color-mix(in srgb, var(--clr-secondary) 30%, transparent);
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-2) var(--sp-4);
    z-index: var(--z-fixed);
    cursor: crosshair;
  }

  .footer__copy {
    color: var(--clr-secondary);
    font-family: var(--font-sans);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
  }

  .footer__links {
    display: flex;
    gap: var(--sp-4);
  }

  .footer__link {
    color: color-mix(in srgb, var(--clr-secondary) 60%, transparent);
    font-family: var(--font-sans);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    text-decoration: none;
    transition: color var(--dur-fast);
  }

  .footer__link:hover {
    color: var(--clr-primary);
  }
</style>
