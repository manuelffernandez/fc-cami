---
import "./footer/styles.css";

const confettiPieces = Array.from({ length: 18 }, (_, index) => {
  const horizontal = (index - 8.5) * 22;
  const vertical = -150 - (index % 4) * 24;
  const delay = index * 35;
  const color = ["#ff77e9", "#8ff5ff", "#ffd166", "#c6ff7d", "#ffffff"][
    index % 5
  ];
  const size = `${4 + (index % 3) * 2}px`;

  return {
    style: `--confetti-x:${horizontal}px; --confetti-y:${vertical}px; --confetti-delay:${delay}ms; --confetti-color:${color}; --confetti-size:${size};`,
  };
});
---

<footer class="footer">
  <p class="footer__copy">(C) 2026 TERMINAL_OS // BIRTHDAY_MODE.INIT</p>

  <nav class="footer__links" aria-label="Footer links">
    <button type="button" class="footer__action" data-gift-trigger>GIFT</button>
    <button type="button" class="footer__action" data-shutdown-trigger
      >SHUTDOWN</button
    >
  </nav>
</footer>

<div class="gift-help" data-help-modal hidden>
  <div class="gift-help__backdrop" data-help-overlay></div>

  <section
    class="gift-help__dialog pixel-border"
    role="dialog"
    aria-modal="true"
    aria-labelledby="gift-help-title"
    tabindex="-1"
  >
    <button
      type="button"
      class="gift-help__close"
      data-help-close
      aria-label="Cerrar premio de cumpleaños"
    >
      ×
    </button>

    <div class="gift-help__stage">
      <div class="gift-help__confetti" aria-hidden="true">
        {
          confettiPieces.map((piece) => (
            <span class="gift-help__confetti-piece" style={piece.style} />
          ))
        }
      </div>

      <div class="gift-help__box-frame">
        <img
          src="/images/footer/gift_box_closed.png"
          alt="Caja de regalo cerrada"
          class="gift-help__box gift-help__box--closed pixelated"
        />
        <img
          src="/images/footer/gift_box_opened.png"
          alt=""
          aria-hidden="true"
          class="gift-help__box gift-help__box--opened pixelated"
        />
        <img
          src="/images/footer/croissant.png"
          alt=""
          aria-hidden="true"
          class="gift-help__croissant pixelated"
        />
      </div>

      <div class="gift-help__voucher">
        <p class="gift-help__eyebrow">BIRTHDAY BONUS UNLOCKED</p>
        <h2 id="gift-help-title">Vale por 1 docena de medialunas</h2>
      </div>
    </div>
  </section>
</div>

<div class="shutdown-modal" data-shutdown-modal hidden>
  <div class="shutdown-modal__backdrop" data-shutdown-overlay></div>

  <section
    class="shutdown-modal__dialog pixel-border"
    role="dialog"
    aria-modal="true"
    aria-labelledby="shutdown-title"
    tabindex="-1"
  >
    <button
      type="button"
      class="shutdown-modal__close"
      data-shutdown-close
      aria-label="Cerrar animación de apagado"
    >
      ×
    </button>

    <div class="shutdown-modal__stage">
      <div class="shutdown-modal__frames" aria-hidden="true">
        {
          Array.from({ length: 6 }, (_, i) => (
            <img
              src={`/images/footer/cake/frame_${i + 1}.png`}
              alt=""
              class="shutdown-modal__frame pixelated"
              data-shutdown-frame
            />
          ))
        }
      </div>

      <div class="shutdown-modal__message" data-shutdown-message>
        <p class="shutdown-modal__eyebrow">BIRTHDAY_SEQUENCE: COMPLETE</p>
        <h2 id="shutdown-title">VELITA SOPLADA</h2>
      </div>
    </div>
  </section>
</div>

<script>
  import setupFooterGiftHelp, { setupShutdown } from "./footer/client";

  setupFooterGiftHelp();
  setupShutdown();
</script>
