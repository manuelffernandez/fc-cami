---
const confettiPieces = Array.from({ length: 18 }, (_, index) => {
  const horizontal = (index - 8.5) * 22;
  const vertical = -150 - (index % 4) * 24;
  const delay = index * 35;
  const color = ['#ff77e9', '#8ff5ff', '#ffd166', '#c6ff7d', '#ffffff'][index % 5];
  const size = `${4 + (index % 3) * 2}px`;

  return {
    style: `--confetti-x:${horizontal}px; --confetti-y:${vertical}px; --confetti-delay:${delay}ms; --confetti-color:${color}; --confetti-size:${size};`,
  };
});
---
<footer class="footer">
  <p class="footer__copy">(C) 2026 TERMINAL_OS // BIRTHDAY_MODE.INIT</p>

  <nav class="footer__links" aria-label="Footer links">
    <button type="button" class="footer__action" data-help-trigger>HELP</button>
    <button type="button" class="footer__action">SHUTDOWN</button>
  </nav>
</footer>

<div class="gift-help" data-help-modal hidden>
  <div class="gift-help__backdrop" data-help-overlay></div>

  <section
    class="gift-help__dialog pixel-border"
    role="dialog"
    aria-modal="true"
    aria-labelledby="gift-help-title"
    tabindex="-1"
  >
    <button
      type="button"
      class="gift-help__close"
      data-help-close
      aria-label="Cerrar premio de cumpleaños"
    >
      ×
    </button>

    <div class="gift-help__stage">
      <div class="gift-help__confetti" aria-hidden="true">
        {
          confettiPieces.map((piece) => (
            <span class="gift-help__confetti-piece" style={piece.style}></span>
          ))
        }
      </div>

      <div class="gift-help__box-frame">
        <img
          src="/images/footer/gift_box_closed.png"
          alt="Caja de regalo cerrada"
          class="gift-help__box gift-help__box--closed pixelated"
        />
        <img
          src="/images/footer/gift_box_opened.png"
          alt=""
          aria-hidden="true"
          class="gift-help__box gift-help__box--opened pixelated"
        />
        <img
          src="/images/footer/croissant.png"
          alt=""
          aria-hidden="true"
          class="gift-help__croissant pixelated"
        />
      </div>

      <div class="gift-help__voucher">
        <p class="gift-help__eyebrow">BIRTHDAY BONUS UNLOCKED</p>
        <h2 id="gift-help-title">Vale por 1 docena de medialunas</h2>
      </div>
    </div>
  </section>
</div>

<style>
  .footer {
    width: 100%;
    margin-top: auto;
    background-color: var(--clr-nav);
    border-top: 1px dotted color-mix(in srgb, var(--clr-secondary) 30%, transparent);
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-2) var(--sp-4);
    cursor: crosshair;
  }

  .footer__copy {
    color: var(--clr-secondary);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
  }

  .footer__links {
    display: flex;
    gap: var(--sp-4);
  }

  .footer__action {
    color: color-mix(in srgb, var(--clr-secondary) 60%, transparent);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
    text-decoration: none;
    transition: color var(--dur-fast);
    background: transparent;
    border: 0;
    padding: 0;
    cursor: crosshair;
  }

  .footer__action:hover {
    color: var(--clr-primary);
  }

  .footer__action:focus-visible,
  .gift-help__close:focus-visible {
    outline: 2px solid var(--clr-primary);
    outline-offset: 4px;
    color: var(--clr-primary);
  }

  .gift-help {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    padding: var(--sp-4);
    z-index: calc(var(--z-fixed) + 40);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-normal) ease;
  }

  .gift-help[hidden] {
    display: none;
  }

  .gift-help.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .gift-help__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, #120022 78%, transparent);
    backdrop-filter: blur(8px);
  }

  .gift-help__dialog {
    position: relative;
    z-index: 1;
    width: min(92vw, 34rem);
    padding: var(--sp-8) var(--sp-6) var(--sp-6);
    background:
      radial-gradient(circle at top, color-mix(in srgb, var(--clr-secondary) 14%, transparent), transparent 50%),
      linear-gradient(180deg, var(--clr-surface-highest), var(--clr-nav));
    border: 1px solid color-mix(in srgb, var(--clr-primary) 24%, transparent);
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--clr-secondary) 25%, transparent),
      0 24px 80px rgba(0, 0, 0, 0.45);
    overflow: hidden;
    isolation: isolate;
  }

  .gift-help__dialog::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 30%);
    pointer-events: none;
  }

  .gift-help__close {
    position: absolute;
    top: var(--sp-2);
    right: var(--sp-2);
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border: 0;
    background: transparent;
    color: color-mix(in srgb, var(--clr-on-bg) 72%, transparent);
    font-size: 1.25rem;
    cursor: crosshair;
    z-index: 2;
  }

  .gift-help__stage {
    position: relative;
    display: grid;
    justify-items: center;
    gap: var(--sp-4);
  }

  .gift-help__box-frame {
    position: relative;
    width: min(16rem, 56vw);
    aspect-ratio: 1;
    display: grid;
    place-items: center;
    filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.45));
    transform-origin: center bottom;
  }

  .gift-help.is-shaking .gift-help__box-frame {
    animation: gift-shake 820ms cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }

  .gift-help__box,
  .gift-help__croissant {
    position: absolute;
    max-width: 100%;
    height: auto;
  }

  .gift-help__box {
    transition:
      opacity 220ms ease,
      transform 320ms ease;
  }

  .gift-help__box--closed {
    opacity: 1;
    transform: scale(1);
  }

  .gift-help__box--opened {
    opacity: 0;
    transform: scale(0.86) translateY(6px);
  }

  .gift-help__croissant {
    width: 46%;
    bottom: 22%;
    opacity: 0;
    transform: translateY(28px) scale(0.3) rotate(-12deg);
    transition:
      opacity 220ms ease,
      transform 520ms cubic-bezier(0.18, 0.89, 0.32, 1.28);
    filter: drop-shadow(0 10px 16px rgba(0, 0, 0, 0.35));
  }

  .gift-help.is-revealed .gift-help__box--closed {
    opacity: 0;
    transform: scale(0.9);
  }

  .gift-help.is-revealed .gift-help__box--opened {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .gift-help.is-revealed .gift-help__croissant {
    opacity: 1;
    transform: translateY(-82px) scale(1.05) rotate(6deg);
  }

  .gift-help__voucher {
    text-align: center;
    display: grid;
    gap: var(--sp-2);
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 220ms ease 120ms,
      transform 320ms ease 120ms;
  }

  .gift-help.is-revealed .gift-help__voucher {
    opacity: 1;
    transform: translateY(0);
  }

  .gift-help__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.24em;
    color: var(--clr-primary);
    text-transform: uppercase;
  }

  .gift-help__voucher h2 {
    color: var(--clr-on-bg);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.05;
    text-wrap: balance;
  }

  .gift-help__confetti {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
  }

  .gift-help__confetti-piece {
    position: absolute;
    left: 50%;
    top: 46%;
    width: var(--confetti-size);
    height: var(--confetti-size);
    background: var(--confetti-color);
    opacity: 0;
    transform: translate(-50%, 0) scale(0);
    image-rendering: pixelated;
    box-shadow:
      var(--confetti-size) 0 0 var(--confetti-color),
      0 var(--confetti-size) 0 var(--confetti-color),
      var(--confetti-size) var(--confetti-size) 0 var(--confetti-color);
  }

  .gift-help.is-revealed .gift-help__confetti-piece {
    animation: confetti-burst 960ms steps(12, end) forwards;
    animation-delay: var(--confetti-delay);
  }

  :global(body.gift-help-open) {
    overflow: hidden;
  }

  @keyframes gift-shake {
    10%,
    90% {
      transform: translate3d(-1px, 0, 0);
    }

    20%,
    80% {
      transform: translate3d(2px, 0, 0);
    }

    30%,
    50%,
    70% {
      transform: translate3d(-5px, 0, 0) rotate(-1deg);
    }

    40%,
    60% {
      transform: translate3d(5px, 0, 0) rotate(1deg);
    }

    100% {
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes confetti-burst {
    0% {
      opacity: 0;
      transform: translate(-50%, 0) scale(0);
    }

    10% {
      opacity: 1;
    }

    55% {
      opacity: 1;
      transform: translate(calc(-50% + (var(--confetti-x) * 0.72)), calc(var(--confetti-y) * 0.78)) scale(1);
    }

    100% {
      opacity: 0;
      transform: translate(calc(-50% + var(--confetti-x)), var(--confetti-y)) scale(1);
    }
  }

  @media (max-width: 640px) {
    .gift-help__dialog {
      padding-left: var(--sp-4);
      padding-right: var(--sp-4);
      padding-bottom: var(--sp-4);
    }

    .gift-help__box-frame {
      width: min(14rem, 68vw);
    }

    .gift-help.is-revealed .gift-help__croissant {
      transform: translateY(-64px) scale(0.95) rotate(6deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gift-help,
    .gift-help__box,
    .gift-help__croissant,
    .gift-help__voucher {
      transition: none;
    }

    .gift-help.is-shaking .gift-help__box-frame,
    .gift-help.is-revealed .gift-help__confetti-piece {
      animation: none;
    }

    .gift-help.is-revealed .gift-help__croissant,
    .gift-help.is-revealed .gift-help__voucher,
    .gift-help.is-revealed .gift-help__box--opened {
      opacity: 1;
      transform: none;
    }
  }

</style>

<script>
  const helpTrigger = document.querySelector('[data-help-trigger]');
  const helpModal = document.querySelector('[data-help-modal]');
  const helpOverlay = document.querySelector('[data-help-overlay]');
  const helpClose = document.querySelector('[data-help-close]');
  const helpDialog = helpModal?.querySelector('.gift-help__dialog');

  if (helpTrigger instanceof HTMLButtonElement && helpModal instanceof HTMLDivElement) {
    let revealTimer;
    let hideTimer;

    const clearTimers = () => {
      if (revealTimer) {
        window.clearTimeout(revealTimer);
      }

      if (hideTimer) {
        window.clearTimeout(hideTimer);
      }

      revealTimer = undefined;
      hideTimer = undefined;
    };

    const openHelp = () => {
      clearTimers();
      helpModal.hidden = false;
      helpModal.classList.remove('is-shaking', 'is-revealed');
      document.body.classList.add('gift-help-open');

      window.requestAnimationFrame(() => {
        helpModal.classList.add('is-visible');

        if (helpDialog instanceof HTMLElement) {
          helpDialog.focus();
        }

        window.requestAnimationFrame(() => {
          helpModal.classList.add('is-shaking');
        });
      });

      revealTimer = window.setTimeout(() => {
        helpModal.classList.remove('is-shaking');
        helpModal.classList.add('is-revealed');
      }, 900);
    };

    const closeHelp = () => {
      if (helpModal.hidden) {
        return;
      }

      clearTimers();
      helpModal.classList.remove('is-shaking', 'is-revealed', 'is-visible');
      document.body.classList.remove('gift-help-open');

      hideTimer = window.setTimeout(() => {
        helpModal.hidden = true;
        helpTrigger.focus();
      }, 220);
    };

    helpTrigger.addEventListener('click', openHelp);
    helpOverlay?.addEventListener('click', closeHelp);
    helpClose?.addEventListener('click', closeHelp);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !helpModal.hidden) {
        closeHelp();
      }
    });
  }
</script>
