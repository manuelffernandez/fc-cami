---
<nav class="navbar" aria-label="Navegación principal">
  <a href="#" class="navbar__brand">CAMI.EXE</a>

  <div class="navbar__links" role="list">
    <a href="#" class="navbar__link navbar__link--active" role="listitem">SYSTEM</a>
  </div>

  <button class="navbar__icon-btn" aria-label="Abrir terminal">
    <span class="material-symbols-outlined" aria-hidden="true">terminal</span>
  </button>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background-color: var(--clr-nav);
    border-bottom: 1px dotted color-mix(in srgb, var(--clr-primary) 30%, transparent);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-4) var(--sp-6);
    z-index: var(--z-fixed);
    transition: transform var(--dur-instant);
  }

  .navbar:active {
    transform: translateY(1px);
  }

  .navbar__brand {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--clr-primary);
    font-family: var(--font-sans);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    text-decoration: none;
    transition: color var(--dur-fast);
  }

  .navbar__brand:hover {
    color: var(--clr-secondary);
  }

  .navbar__links {
    display: none;
    align-items: center;
    gap: var(--sp-8);
  }

  @media (min-width: 768px) {
    .navbar__links {
      display: flex;
    }
  }

  .navbar__link {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    text-decoration: none;
    color: color-mix(in srgb, var(--clr-primary) 70%, transparent);
    padding: 0.25rem;
    transition: color var(--dur-fast), background-color var(--dur-fast);
  }

  .navbar__link:hover {
    color: var(--clr-primary);
    background-color: color-mix(in srgb, var(--clr-primary) 10%, transparent);
  }

  .navbar__link--active {
    color: var(--clr-secondary);
    border-bottom: 2px solid var(--clr-secondary);
    padding-bottom: var(--sp-1);
  }

  .navbar__icon-btn {
    display: flex;
    align-items: center;
    color: var(--clr-primary);
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--sp-2);
    transition: background-color var(--dur-fast);
  }

  .navbar__icon-btn:hover {
    background-color: color-mix(in srgb, var(--clr-primary) 10%, transparent);
  }
</style>
